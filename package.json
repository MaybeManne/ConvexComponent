{
  "name": "convex-browser-use",
  "version": "1.0.0",
  "private": true,
  "description": "Convex Component for durable browser automation using Browser Use Cloud",
  "workspaces": [
    "component",
    "example"
  ],
  "scripts": {
    "dev": "concurrently -n convex,next -c blue,green \"npm run dev:convex\" \"npm run dev:example\"",
    "dev:convex": "cd example && npx convex dev",
    "dev:example": "cd example && npm run dev",
    "dev:test": "cd example && BROWSER_USE_TEST_MODE=1 npx convex dev",
    "build:example": "cd example && npm run build",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "cd example && npm run test:e2e",
    "test:headed": "cd example && npm run test:e2e:headed",
    "test:backend": "cd example && npm run test:backend",
    "test:install": "cd example && npm run test:install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "convex": "^1.32.0"
  }
}
